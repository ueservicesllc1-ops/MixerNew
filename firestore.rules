rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && 
             (request.auth.uid == 'qMQmpXvp1Fe5da8Ud64tyNgcRbH2' || 
              (request.auth.token.email != null && 
               request.auth.token.email.lower() == 'ueservicesllc1@gmail.com'));
    }

    // -- USERS: owner or admin
    match /users/{userId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();

      // Metadatos de importación “multitrack desde PC” (Zion Stage desktop). Solo el dueño o admin.
      // Ruta usada por la app: users/{uid}/pcLibrary/{songId}
      match /pcLibrary/{songId} {
        allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      }
    }

    // -- SETLISTS: owner or admin
    match /setlists/{setlistId} {
      allow read, write: if (request.auth != null && request.auth.uid == resource.data.userId) || isAdmin();
      allow create: if (request.auth != null && request.resource.data.userId == request.auth.uid) || isAdmin();
    }

    // -- SONGS: public can read all songs (for metadata); write admin or owner
    match /songs/{songId} {
      allow read: if true;
      allow write: if isAdmin() || (request.auth != null && (resource == null || resource.data.userEmail == request.auth.token.email));
    }

    // -- MASTER_ARTISTS: admin can manage, any authenticated or public can read
    match /master_artists/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // -- APP VERSIONS: lectura pública (app busca actualización).
    // create: sin auth — el script Node (upload-final-apk.mjs) usa Firestore SIN usuario logueado.
    // update/delete: solo admin (evita que cualquiera borre versiones).
    match /app_versions/{docId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // -- SELLER APPLICATIONS: owner can create, admin can manage
    match /seller_applications/{userId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
    }

    // -- LYRICS: authenticated users
    match /lyrics/{doc} {
      allow read, write: if request.auth != null;
    }

    // -- CHORDS: authenticated users
    match /chords/{doc} {
      allow read, write: if request.auth != null;
    }

    // -- PARTITURAS (linked to songs, for personal use in mixer)
    match /partituras/{doc} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // -- PARTITURAS_VENTA (sheet music for sale by sellers)
    match /partituras_venta/{pvId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());

      // Star ratings subcollection: any authenticated user can rate, only their own doc
      match /ratings/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // -- BANNERS: public can read; write admin
    match /banners/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // -- COUPONS: solo admin (panel Admin)
    match /coupons/{docId} {
      allow read, write: if isAdmin();
    }

    // -- CONTACTS: anyone can create; only admin can read
    match /contacts/{doc} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // -- ACCOUNT DELETION REQUESTS: public create; admin reads / manages
    match /account_deletion_requests/{doc} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // -- Desktop: clicks de descarga del instalador (web). Solo admin lee.
    match /desktop_download_events/{id} {
      // `serverTimestamp()` no siempre cumple `== request.time` en reglas; ventana corta alrededor del reloj del servidor.
      allow create: if request.resource.data.keys().hasOnly(['source', 'versionName', 'createdAt', 'locale'])
        && request.resource.data.source in ['landing_modal', 'landing_hero', 'landing_win']
        && request.resource.data.versionName is string
        && request.resource.data.versionName.size() > 0
        && request.resource.data.versionName.size() < 48
        && request.resource.data.createdAt is timestamp
        && request.resource.data.createdAt <= request.time + duration.value(5, 's')
        && request.resource.data.createdAt >= request.time - duration.value(5, 's')
        && request.resource.data.locale is string
        && request.resource.data.locale.size() < 48;
      allow read, update, delete: if isAdmin();
    }

    // -- Desktop: heartbeat por instalación (clientId = UUID). Solo admin lee/borra; create/update públicos acotados.
    match /desktop_clients/{clientId} {
      allow read, delete: if isAdmin();
      allow create, update: if clientId.matches('^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$')
        && request.resource.data.keys().hasOnly(['lastSeenAt', 'firstSeenAt', 'versionName', 'platform', 'firebaseUid'])
        && request.resource.data.lastSeenAt is timestamp
        && request.resource.data.lastSeenAt <= request.time + duration.value(5, 's')
        && request.resource.data.lastSeenAt >= request.time - duration.value(5, 's')
        && request.resource.data.versionName is string
        && request.resource.data.versionName.size() > 0
        && request.resource.data.versionName.size() <= 32
        && request.resource.data.platform == 'electron_win'
        && (!('firstSeenAt' in request.resource.data)
            || (request.resource.data.firstSeenAt is timestamp
                && (resource == null || request.resource.data.firstSeenAt == resource.data.firstSeenAt)))
        && (!('firebaseUid' in request.resource.data)
            || (request.resource.data.firebaseUid is string && request.resource.data.firebaseUid.size() <= 128));
    }
  }
}
