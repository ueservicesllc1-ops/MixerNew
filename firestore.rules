rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email != null && 
             request.auth.token.email.lower() == 'ueservicesllc1@gmail.com';
    }

    // ── USERS: owner or admin
    match /users/{userId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
    }

    // ── SETLISTS: owner or admin
    match /setlists/{setlistId} {
      allow read, write: if (request.auth != null && request.auth.uid == resource.data.userId) || isAdmin();
      allow create: if (request.auth != null && request.resource.data.userId == request.auth.uid) || isAdmin();
    }

    // ── SONGS: any authenticated user can read; write admin or owner
    match /songs/{songId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || (request.auth != null && (resource == null || resource.data.userEmail == request.auth.token.email));
    }

    // ── MASTER_ARTISTS: admin can manage, any authenticated can read
    match /master_artists/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── SELLER APPLICATIONS: owner can create, admin can manage
    match /seller_applications/{userId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
    }

    // ── LYRICS: authenticated users
    match /lyrics/{doc} {
      allow read, write: if request.auth != null;
    }

    // ── CHORDS: authenticated users
    match /chords/{doc} {
      allow read, write: if request.auth != null;
    }

    // ── CONTACTS: anyone can create; only admin can read
    match /contacts/{doc} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
